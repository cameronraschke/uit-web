{
	"compilerOptions": {
		"noImplicitAny": true,
		"noUnusedLocals": true,
		"noUnusedParameters": true,
		"noImplicitReturns": true,
		"noFallthroughCasesInSwitch": true,
		"noImplicitThis": true,
		"strictNullChecks": true,
		"removeComments": true,
		"noEmitOnError": true,
		"skipLibCheck": true,
		"target": "es2025",
		"lib": ["es2025", "dom", "ESNext"],
		"sourceMap": false
	},
	"include": ["./*.ts"],
}